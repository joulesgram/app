// All monetary amounts (joulesBalance, LedgerEntry.amount, balanceAfter) are
// stored in joules (J), where 1 kJ = 1000 J. Convert to kJ only at the UI layer.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Entry‑type enum ────────────────────────────────────────────────
// Categories enforced in src/lib/integrity.ts — keep in sync.
enum LedgerEntryType {
  // Debit types (amount < 0, references a user action)
  COMPUTE_FEE
  RATING_STAKE
  STAKE_SLASH
  AGENT_REGISTRATION_FEE
  BOOST_FEE

  // Pool mint types (amount > 0, references a DailySettlement)
  CREATOR_REWARD
  CURATOR_REWARD
  ENGAGEMENT_BONUS

  // Reserve grant types (amount > 0)
  UPLOAD_REWARD
  REFERRAL_BONUS
  LEADERBOARD_BONUS
  GENESIS_BONUS
  FAUCET_GRANT

  // Stake resolution types (amount > 0, references HumanRating)
  STAKE_RETURN
  STAKE_BONUS

  // Pre-Scale Mode types (amount > 0 for user, < 0 for treasury)
  REGEN_DRIP
  DAILY_LOGIN_BONUS
  RATE_EARN_FLAT
  PRE_SCALE_POST_GRANT

  // Neutral (uncategorized) — used for migration opening balances.
  // Intentionally not in any category set in src/lib/integrity.ts;
  // passes Rules #1 and #2 trivially because both filter on their
  // respective category sets at the DB layer. Either sign allowed.
  OPENING_BALANCE
}

// ─── Models ─────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  joulesBalance Decimal  @default(0) @db.Decimal(20, 4)
  userNumber    Int      @unique
  referralCode  String   @unique @default(cuid())
  referredBy    String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  // Pre-Scale Mode fields
  lastLoginBonusDate   DateTime?
  ratingsSinceLastPost Int       @default(0)

  photos        Photo[]
  agents        Agent[]
  humanRatings  HumanRating[]
  ledgerEntries LedgerEntry[]
}

model Photo {
  id        String   @id @default(cuid())
  imageUrl  String
  userId    String
  category  String?
  aiScore   Float?
  critique  String?
  computeKJ Float    @default(0)
  nsfw      Boolean  @default(false)
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  humanRatings HumanRating[]
  agentRatings AgentRating[]
}

model Agent {
  id            String   @id @default(cuid())
  name          String
  persona       String?
  modelProvider String
  modelId       String
  creatorId     String
  color         String?
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())

  creator      User          @relation(fields: [creatorId], references: [id])
  agentRatings AgentRating[]
}

model HumanRating {
  id        String   @id @default(cuid())
  photoId   String
  userId    String
  score     Float
  createdAt DateTime @default(now())

  photo Photo @relation(fields: [photoId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([photoId, userId])
}

model AgentRating {
  id            String   @id @default(cuid())
  photoId       String
  agentId       String
  score         Float
  critique      String?
  computeJoules Float    @default(0)
  createdAt     DateTime @default(now())

  photo Photo @relation(fields: [photoId], references: [id])
  agent Agent @relation(fields: [agentId], references: [id])
}

model LedgerEntry {
  id            String          @id @default(cuid())
  userId        String
  entryType     LedgerEntryType
  amount        Decimal         @db.Decimal(20, 4)
  balanceAfter  Decimal         @db.Decimal(20, 4)
  referenceType String?
  referenceId   String?
  description   String?
  createdAt     DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entryType])
}

// ─── Pre-Scale Mode tables ──────────────────────────────────────────

model BootstrapPool {
  poolId        String    @id
  totalMintedKj BigInt
  remainingKj   BigInt
  createdAt     DateTime  @default(now())
  closedAt      DateTime?
}

model ActiveUserCountDaily {
  date        DateTime @id @db.Date
  activeUsers Int
  recordedAt  DateTime @default(now())
}

model CronRunLog {
  id          String   @id @default(cuid())
  jobName     String
  bucketKey   String
  completedAt DateTime @default(now())

  @@unique([jobName, bucketKey])
}

// ─── Admin audit log ───────────────────────────────────────────────

model AdminAction {
  id           String   @id @default(cuid())
  operatorId   String
  operation    String   // "credit_debit" | "reset_counter" | "set_referredby"
  targetUserId String?
  payload      Json
  result       String   // "pending" | "success" | "failed"
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([operatorId])
}
